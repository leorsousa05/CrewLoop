{
  "name": "@archznn/crewloop-dashboard",
  "version": "0.7.0",
  "description": "Real-time CrewLoop skill dashboard server and UI",
  "license": "MIT",
  "author": "leorsousa05",
  "repository": {
    "type": "git",
    "url": "https://github.com/leorsousa05/CrewLoop.git"
  },
  "homepage": "https://leorsousa05.github.io/CrewLoop/",
  "bin": {
    "crewloop-dashboard": "bin/crewloop-dashboard.js",
    "crewloop-shim": "bin/crewloop-shim.js"
  },
  "files": [
    "bin/",
    "dist/",
    "public/",
    "config-examples/",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "cd ui && vite build",
    "dev": "cd ui && vite",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json",
    "test": "npm run test:server && npm run test:ui",
    "test:server": "node --test dist/**/*.test.js",
    "test:ui": "vitest run --root ui --config vitest.config.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-3d": "^1.26.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "ai-agent",
    "crewloop",
    "dashboard",
    "observability"
  ]
}
