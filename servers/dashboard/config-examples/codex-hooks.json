{
  "$schema": "https://example.com/codex-hooks-schema.json",
  "description": "Codex CLI hook configuration for CrewLoop dashboard.",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "crewloop-shim",
            "args": ["codex", "--default-skill", "orchestrator"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "crewloop-shim",
            "args": ["codex", "--default-skill", "orchestrator"]
          }
        ]
      }
    ]
  }
}
